{
  "name": "scaffold-ui-kit",
  "version": "2.0.0",
  "description": "Scaffold framework-agnostic UI kits powered by js-template-engine: define components once as data, ship them for React, Vue, Svelte, and HTML",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "bin": {
    "scaffold-ui-kit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit -p tsconfig.type-check.json"
  },
  "dependencies": {
    "@js-template-engine/core": "workspace:^",
    "@js-template-engine/extension-bem": "workspace:^",
    "@js-template-engine/extension-react": "workspace:^",
    "@js-template-engine/extension-svelte": "workspace:^",
    "@js-template-engine/extension-tailwind": "workspace:^",
    "@js-template-engine/extension-vue": "workspace:^",
    "@js-template-engine/types": "workspace:^",
    "commander": "^12.1.0",
    "enquirer": "^2.4.1",
    "jiti": "^2.4.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djurnamn/js-template-engine.git",
    "directory": "packages/scaffold-ui-kit"
  },
  "keywords": [
    "js-template-engine",
    "ui-kit",
    "component-library",
    "design-system",
    "scaffolding",
    "react",
    "vue",
    "svelte"
  ],
  "author": "Björn Djurnamn <bjorn@djurnamn.co>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/djurnamn/js-template-engine/issues"
  },
  "homepage": "https://github.com/djurnamn/js-template-engine/tree/main/packages/scaffold-ui-kit",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  }
}
