{
  "name": "@js-template-engine/extension-vue",
  "version": "2.0.0",
  "description": "Vue extension for the JS Template Engine: renders data-defined component templates as Vue Single File Components",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit -p tsconfig.type-check.json"
  },
  "dependencies": {
    "@js-template-engine/core": "workspace:^",
    "@js-template-engine/types": "workspace:^"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djurnamn/js-template-engine.git",
    "directory": "packages/extension-vue"
  },
  "keywords": [
    "js-template-engine",
    "vue",
    "sfc",
    "extension"
  ],
  "author": "Björn Djurnamn <bjorn@djurnamn.co>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/djurnamn/js-template-engine/issues"
  },
  "homepage": "https://github.com/djurnamn/js-template-engine/tree/main/packages/extension-vue",
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  }
}
